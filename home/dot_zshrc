# Powerlevel10k instant prompt を有効化（.zshrc の最上部に配置する必要がある）
# キャッシュファイルが存在する場合のみ有効化（初回実行時はスキップ）
# instant_prompt が有効な場合、p10k が OSC 10/11 などのターミナルクエリを適切に
# 処理するため、エスケープシーケンスの漏れを根本的に防止できる
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ユーザーローカルのbinディレクトリをPATHの先頭に追加
export PATH="$HOME/.local/bin:$PATH"

# ターミナル背景色を環境変数で事前に宣言し、OSC 11 クエリを送信させない
#
# 【なぜこれが必要か】
# p10k・vim・neovim などは「ターミナルの背景色が不明」な場合に
# OSC 11 (`\e]11;?\a`) を送信してターミナルへ問い合わせる。
# ターミナルはその応答 (`\e]11;rgb:cccc/cccc/cccc\a`) を stdin に書き込むが、
# タイミングによってはシェルや自動化スクリプトの stdin に混入する。
# これらの変数を事前に設定しておくと、ツールは問い合わせを省略する。
# export により子プロセス（非インタラクティブな自動化スクリプト含む）にも継承される。
#
# 値: COLORFGBG=「前景色番号;背景色番号」（15=white, 0=black = ダーク背景）
#   POWERLEVEL9K_TERM_BACKGROUND: 0=黒（ダーク背景）を p10k に明示指定
# 既に設定済みの場合は上書きしない（ユーザー側の明示的な設定を尊重する）
export COLORFGBG="${COLORFGBG:-15;0}"
typeset -g POWERLEVEL9K_TERM_BACKGROUND="${POWERLEVEL9K_TERM_BACKGROUND:-0}"

# ターミナルエスケープシーケンス応答をドレインする関数
# DA1/DA2・OSC 10/11（背景色クエリ）などのターミナル問い合わせ応答を破棄し、
# プロンプトへの混入を防ぐ
#
# 【二層防衛: precmd ドレイン + 起動時ドレインの役割分担】
# - precmd: すべての初期化完了後かつプロンプト表示前に毎回実行。
#   p10k 等の末尾ロードされるツールのクエリ応答も含め、継続的に捕捉する主要手段。
#   ただし初回呼び出し（シェル起動時の最初のプロンプト表示前）はスキップする。
#   これは tmux send-keys などで先行入力されたコマンドを保護するためである。
# - 起動時ドレイン（.zshrc.d/ ロード後）: デフォルト無効・opt-in。
#   ZSH_STARTUP_ESC_DRAIN=1 の場合のみ実行。
#   初期化中のツールが送信したクエリ応答を安全網として捕捉するが、
#   ユーザーの先行入力を誤って破棄しないよう非ブロッキングで動作する。
#
# 【初回スキップが必要な理由】
# Agent Teams など、tmux セッションの起動直後に tmux send-keys でコマンドを
# 送信するケースがある。シェルの初期化（.zshrc ロード）中にコマンドが PTY
# バッファに蓄積され、最初の precmd 実行時にドレインが誤ってコマンドを
# 消費してしまう問題を防ぐ。
if [[ -t 0 && -t 1 ]]; then
  # 初回呼び出しスキップ用フラグ（1=スキップ待機中、0=通常動作）
  typeset -g _drain_first_call=1
  function _drain_esc_responses() {
    # 初回呼び出し（シェル起動時の最初のプロンプト表示前）はスキップ
    # tmux send-keys などで先行入力されたコマンドを保護するため
    if [[ "${_drain_first_call:-0}" -eq 1 ]]; then
      _drain_first_call=0
      return 0
    fi
    local _discard
    # フェーズ 1: 非ブロッキングで即座にチェック
    # データがなければ即座にリターンし、プロンプト表示の遅延を防ぐ
    IFS= read -t 0 -k 10000 _discard 2>/dev/null || return 0
    # フェーズ 2: データがあった場合、続けて届く応答も全て読み捨て
    # -t 0.02（20ms）: 少し待ってバッファに残った応答を取り逃がさない
    while IFS= read -t 0.02 -k 10000 _discard 2>/dev/null; do :; done
  }
  # add-zsh-hook を用いて precmd フックに idempotent に登録する
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _drain_esc_responses
fi

# 追加の設定ファイルを読み込む
if [ -d "$HOME/.zshrc.d" ]; then
  # マッチするファイルがない場合にエラーを出さないようにする
  setopt nullglob
  # ~/.zshrc.d/ 以下の .zsh ファイルを辞書順に読み込む
  for f in ${(on)${(f)"$(LC_ALL=C print -rl -- "$HOME/.zshrc.d/"*.zsh | LC_ALL=C sort)"}}; do
    [ -r "$f" ] && source "$f"
  done
  unset f
  # オプションを元に戻す
  unsetopt nullglob
fi

# 起動時ドレイン（.zshrc.d/ 全ロード後）- opt-in（デフォルト無効）
# ZSH_STARTUP_ESC_DRAIN=1 を設定した場合のみ実行される。
# ユーザーの先行入力を誤って破棄しないよう -t 0（非ブロッキング）で動作する。
if [[ -t 0 && -t 1 && "${ZSH_STARTUP_ESC_DRAIN:-}" == "1" ]]; then
  IFS= read -t 0 -k 10000 __drain_discard 2>/dev/null || true
  unset __drain_discard
fi
