{
  "hooksConfig": {
    "enabled": true
  },
  "hooks": {
    "AfterTool": [
      {
        "hooks": [
          {
            "name": "tmux-ipc-check",
            "type": "command",
            "command": "~/.gemini/hooks/tmux-ipc-check.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "notify-completion",
            "type": "command",
            "command": "~/.gemini/hooks/notify-completion.sh"
          }
        ]
      }
    ]
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "previewFeatures": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d"
    }
  },
  "ui": {
    "hideTips": true,
    "loadingPhrases": "off",
    "showShortcutsHint": false
  },
  "model": {
    "skipNextSpeakerCheck": true,
    "disableLoopDetection": true
  },
  "context": {
    "fileFiltering": {
      "respectGitIgnore": false
    }
  }
}
