# Only run in interactive shells.
case $- in
  *i*) ;;
  *) return ;;
esac

# ターミナル背景色を環境変数で事前に宣言し、OSC 11 クエリを送信させない
#
# 【なぜこれが必要か】
# vim・neovim などは「ターミナルの背景色が不明」な場合に
# OSC 11 (`\e]11;?\a`) を送信してターミナルへ問い合わせる。
# ターミナルはその応答 (`\e]11;rgb:cccc/cccc/cccc\a`) を stdin に書き込むが、
# タイミングによってはシェルや自動化スクリプトの stdin に混入する。
# この変数を設定しておくと、ツールは問い合わせを省略する。
# export により子プロセス（非インタラクティブな自動化スクリプト含む）にも継承される。
#
# 値: COLORFGBG=「前景色番号;背景色番号」（15=white, 0=black = ダーク背景）
# 既に設定済みの場合は上書きしない（ユーザー側の明示的な設定を尊重する）
export COLORFGBG="${COLORFGBG:-15;0}"

# ターミナルエスケープシーケンス応答をドレインする関数
# DA1/DA2・OSC 10/11（背景色クエリ）などのターミナル問い合わせ応答を破棄し、
# プロンプトへの混入を防ぐ
#
# 【二層防衛: PROMPT_COMMAND ドレイン + 起動時ドレインの役割分担】
# - PROMPT_COMMAND: コマンド実行後・プロンプト表示前に毎回実行。
#   あらゆるタイミングで発生する応答を継続的に捕捉する主要手段。
# - 起動時ドレイン（.bashrc.d/ ロード後）: デフォルト無効・opt-in。
#   BASH_DRAIN_ESC_ON_STARTUP=1 が設定されている場合のみ実行。
#   初期化中のツールが送信したクエリ応答を安全網として捕捉するが、
#   ユーザーの先行入力を誤って破棄しないよう非ブロッキングで動作する。
if [ -t 0 ] && [ -t 1 ]; then
  _drain_esc_responses() {
    local _discard
    # フェーズ1: 非ブロッキングで即座にチェック
    # データがなければ即座にリターンし、プロンプト表示の遅延を防ぐ
    IFS= read -r -t 0 -n 10000 _discard 2>/dev/null || return 0
    # フェーズ2: データがあった場合、続けて届く応答も全て読み捨て
    # -t 0.02（20ms）: 少し待ってバッファに残った応答を取り逃がさない
    while IFS= read -r -t 0.02 -n 10000 _discard 2>/dev/null; do :; done
  }
  # PROMPT_COMMAND への登録は idempotent に行う
  if [[ "${PROMPT_COMMAND}" != *"_drain_esc_responses"* ]]; then
    PROMPT_COMMAND="${PROMPT_COMMAND:+${PROMPT_COMMAND}; }_drain_esc_responses"
  fi
fi

# Load extra config fragments.
if [ -d "$HOME/.bashrc.d" ]; then
  shopt -s nullglob
  mapfile -t __bashrc_files < <(LC_ALL=C printf '%s\n' "$HOME/.bashrc.d/"*.sh | LC_ALL=C sort)
  for f in "${__bashrc_files[@]}"; do
    # shellcheck source=/dev/null
    [ -r "$f" ] && . "$f"
  done
  unset f __bashrc_files
  shopt -u nullglob
fi

# 起動時ドレイン（.bashrc.d/ 全ロード後）- opt-in（デフォルト無効）
# BASH_DRAIN_ESC_ON_STARTUP=1 を設定した場合のみ実行される。
# ユーザーの先行入力を誤って破棄しないよう -t 0（非ブロッキング）で動作する。
if [ -t 0 ] && [ -t 1 ] && [ "${BASH_DRAIN_ESC_ON_STARTUP:-}" = "1" ]; then
  IFS= read -r -t 0 -n 10000 __drain_discard 2>/dev/null || true
  unset __drain_discard
fi
