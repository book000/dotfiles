{
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SIMPLE_SYSTEM_PROMPT": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_EXTRA_USAGE_COMMAND": "1",
    "ENABLE_TOOL_SEARCH": "auto",
    "IS_DEMO": "1"
  },
  "model": "opusplan",
  "autoMemoryEnabled": false,
  "feedbackSurveyRate": 0,
  "showClearContextOnPlanAccept": true,
  "awaySummaryEnabled": false,
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/completion-notify/notify-completion.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/require-code-review-fixes.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/require-review-thread-fixes.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/completion-notify/notify-askuserquestion.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/tomachi/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tmux-ipc-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/code-review-immediate-fix.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/completion-notify/notify-post-tool-use.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/completion-notify/notify-permission-request.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/completion-notify/notify-notification.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/completion-notify/notify-user-prompt-submit.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "wakatime": {
      "source": {
        "source": "github",
        "repo": "wakatime/claude-code-wakatime"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "showThinkingSummaries": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/hooks/statusline.sh"
  }
}
