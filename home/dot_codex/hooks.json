{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/tmux-ipc-check.sh",
            "statusMessage": "tmux IPC メッセージを確認中...",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/tmux-ipc-check.sh",
            "statusMessage": "tmux IPC メッセージを確認中...",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/tmux-ipc-check.sh",
            "statusMessage": "tmux IPC メッセージを確認中...",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/scripts/completion-notify/notify-completion.sh",
            "statusMessage": "Codex の完了通知を確認中...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
